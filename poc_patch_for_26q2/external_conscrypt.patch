+package android.security.net.config;
+
+import java.security.Provider;
+
+/** @hide */
+public final class RemoteSigningProvider extends Provider {
+    private static final long serialVersionUID = 1L;
+
+    /** @hide */
+    public RemoteSigningProvider() {
+        super("NiapRemoteSigning", 1.0, "JCA Provider for NIAP remote KeyStore signing");
+        Provider.Service service = new Provider.Service(
+                this, "Signature", "NONEwithECDSA",
+                RemoteSignatureSpi.class.getName(), null, null) {
+            @Override
+            public boolean supportsParameter(Object parameter) {
+                return parameter instanceof RemotePrivateKey;
+            }
+        };
+        putService(service);
+    }
+}
