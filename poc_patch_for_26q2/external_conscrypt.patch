+package android.security.net.config;
+
+import java.io.ByteArrayOutputStream;
+import java.security.InvalidKeyException;
+import java.security.PrivateKey;
+import java.security.PublicKey;
+import java.security.SignatureException;
+import java.security.SignatureSpi;
+
+/** @hide */
+public final class RemoteSignatureSpi extends SignatureSpi {
+    private final ByteArrayOutputStream mBuffer = new ByteArrayOutputStream();
+    private RemotePrivateKey mPrivateKey;
+
+    @Override
+    protected void engineInitSign(PrivateKey privateKey) throws InvalidKeyException {
+        if (!(privateKey instanceof RemotePrivateKey)) {
+            throw new InvalidKeyException("RemoteSignatureSpi requires a RemotePrivateKey; got "
+                    + (privateKey != null ? privateKey.getClass().getName() : "null"));
+        }
+        mPrivateKey = (RemotePrivateKey) privateKey;
+        mBuffer.reset();
+    }
+
+    @Override
+    protected void engineInitVerify(PublicKey publicKey) throws InvalidKeyException {
+        throw new UnsupportedOperationException("engineInitVerify not supported");
+    }
+
+    @Override
+    protected void engineUpdate(byte b) throws SignatureException {
+        mBuffer.write(b & 0xFF);
+    }
+
+    @Override
+    protected void engineUpdate(byte[] b, int off, int len) throws SignatureException {
+        mBuffer.write(b, off, len);
+    }
+
+    @Override
+    protected byte[] engineSign() throws SignatureException {
+        if (mPrivateKey == null) {
+            throw new SignatureException("engineSign called before engineInitSign");
+        }
+        byte[] digest = mBuffer.toByteArray();
+        mBuffer.reset();
+        return mPrivateKey.sign(digest);
+    }
+
+    @Override
+    protected boolean engineVerify(byte[] sigBytes) throws SignatureException {
+        throw new UnsupportedOperationException("engineVerify not supported");
+    }
+
+    /**
+     * @deprecated Use engineSetParameter instead.
+     */
+    @Override
+    @Deprecated
+    protected void engineSetParameter(String param, Object value) {
+        throw new UnsupportedOperationException("engineSetParameter not supported");
+    }
+
+    /**
+     * @deprecated Use engineGetParameter instead.
+     */
+    @Override
+    @Deprecated
+    protected Object engineGetParameter(String param) {
+        return null;
+    }
+}
