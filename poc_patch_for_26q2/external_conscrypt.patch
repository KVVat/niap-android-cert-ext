+    private void resolveNiapStrictProfile(NetworkSecurityConfig.Builder builder) {
+        if (mContext == null) {
+            return;
+        }
+        try {
+            Context certManagerContext = mContext.createPackageContext(
+                    "com.android.niap.cert.service", 
+                    Context.CONTEXT_IGNORE_SECURITY
+            );
+            int resId = certManagerContext.getResources().getIdentifier(
+                    "niap_strict_network_security_config", 
+                    "xml", 
+                    "com.android.niap.cert.service"
+            );
+            if (resId != 0) {
+                XmlConfigSource strictSource = new XmlConfigSource(
+                        certManagerContext, 
+                        resId, 
+                        certManagerContext.getApplicationInfo()
+                );
+                NetworkSecurityConfig strictConfig = strictSource.getDefaultConfig();
+                if (strictConfig != null) {
+                    builder.setNiapStrictSigAlg(strictConfig.getNiapStrictSigAlg());
+                    builder.setProhibitedTldWildcards(strictConfig.getProhibitedTldWildcards());
+                    builder.setAllowedCipherSuites(strictConfig.getAllowedCipherSuites());
+                    builder.setTrustAnchorPolicy(strictConfig.getTrustAnchorPolicy());
+                    builder.setLimitTlsVersion(strictConfig.getLimitTlsVersion());
+                    builder.setNiapMinEcKeySize(strictConfig.getNiapMinEcKeySize());
+                    builder.setNiapMinRsaKeySize(strictConfig.getNiapMinRsaKeySize());
+                    builder.setNiapPkixRevocationMode(strictConfig.getNiapPkixRevocationMode());
+                    builder.setEnforceMandatoryExtensions(strictConfig.getEnforceMandatoryExtensions());
+                    builder.setEnforceEku(strictConfig.getEnforceEku());
+                    builder.setRequiredEku(strictConfig.getRequiredEku());
+                    builder.setEnforceCaConstraints(strictConfig.getEnforceCaConstraints());
+                }
+            } else {
+                android.util.Log.e("XmlConfigSource", "niap_strict_network_security_config XML resource not found in cert-manager-system");
+            }
+        } catch (Exception e) {
+            android.util.Log.e("XmlConfigSource", "Failed to resolve niap-strict profile from cert-manager-system", e);
+        }
+    }
+
     public static class ParserException extends Exception {
         public ParserException(XmlPullParser parser, String message, Throwable cause) {
             super(message + " at: " + parser.getPositionDescription(), cause);
