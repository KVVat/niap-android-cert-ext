+/** @hide */
+public final class NetworkSecurityKeyManager extends X509ExtendedKeyManager {
+    private static final String TAG = "NetworkSecurityKeyManager";
+    private static final Object sLock = new Object();
+    private static INiapCertManager sService = null;
+
+    private final X509KeyManager mDelegate;
+
+    /** @hide */
+    public NetworkSecurityKeyManager(X509KeyManager delegate) {
+        mDelegate = delegate;
+    }
+
+    private static INiapCertManager getService(Context context) {
+        synchronized (sLock) {
+            if (sService != null && sService.asBinder().isBinderAlive()) {
+                return sService;
+            }
+            final java.util.concurrent.CountDownLatch latch = new java.util.concurrent.CountDownLatch(1);
+            final INiapCertManager[] serviceHolder = new INiapCertManager[1];
+            ServiceConnection connection = new ServiceConnection() {
+                @Override
+                public void onServiceConnected(ComponentName name, IBinder binder) {
+                    serviceHolder[0] = INiapCertManager.Stub.asInterface(binder);
+                    latch.countDown();
+                }
+                @Override
+                public void onServiceDisconnected(ComponentName name) {
+                    synchronized (sLock) {
+                        sService = null;
+                    }
+                }
+            };
+            Intent intent = new Intent("com.android.niap.cert.manager.INiapCertManager");
+            intent.setPackage("com.android.niap.cert.service");
+            boolean bound = context.bindService(intent, connection, Context.BIND_AUTO_CREATE);
+            if (!bound) {
+                Log.e(TAG, "Failed to bind to cert-manager-system");
+                return null;
+            }
+            try {
+                if (latch.await(5, java.util.concurrent.TimeUnit.SECONDS)) {
+                    sService = serviceHolder[0];
+                    return sService;
+                } else {
+                    Log.e(TAG, "Timeout waiting for cert-manager-system connection");
+                }
+            } catch (InterruptedException e) {
+                Log.e(TAG, "Interrupted waiting for connection", e);
+            }
+            return null;
+        }
+    }
+
+    private String getHostname(Socket socket) {
+        if (socket == null) {
+            return null;
+        }
+        try {
+            // Using reflection or standard socket properties:
+            if (socket.getInetAddress() != null) {
+                return socket.getInetAddress().getHostName();
+            }
+        } catch (Exception e) {
+            Log.e(TAG, "Failed to get hostname from socket", e);
+        }
+        return null;
+    }
+
+    private String getHostname(SSLEngine engine) {
+        if (engine == null) {
+            return null;
+        }
+        return engine.getPeerHost();
+    }
+
+    private String chooseAlias(String[] keyType, Principal[] issuers, String hostname) {
+        if (hostname == null) {
+            return null;
+        }
+        ApplicationConfig appConfig = ApplicationConfig.getDefaultInstance();
+        if (appConfig == null) {
+            return null;
+        }
+        NetworkSecurityConfig config = appConfig.getConfigForHostname(hostname);
+        if (config == null || config.getEstServerUrl() == null) {
+            return null;
+        }
+
+        Context context = getCurrentApplicationContext();
+        if (context == null) {
+            Log.e(TAG, "No app context, cannot check client identity");
+            return null;
+        }
+
+        final INiapCertManager service = getService(context);
+        if (service == null) {
+            Log.e(TAG, "Failed to get cert-manager service");
+            return null;
+        }
+
+        final String alias = hostname;
+        try {
+            if (!service.hasEnrollment(alias)) {
+                Log.i(TAG, "Enrolling client identity via EST for alias: " + alias);
+                int resId = context.getResources().getIdentifier("est_validation_ca", "raw", context.getPackageName());
+                String caPem = null;
+                if (resId != 0) {
+                    try (java.io.InputStream is = context.getResources().openRawResource(resId);
+                         java.io.ByteArrayOutputStream bos = new java.io.ByteArrayOutputStream()) {
+                        byte[] buf = new byte[1024];
+                        int read;
+                        while ((read = is.read(buf)) != -1) {
+                            bos.write(buf, 0, read);
+                        }
+                        caPem = bos.toString("UTF-8");
+                    }
+                }
+                final java.util.concurrent.CountDownLatch enrollLatch = new java.util.concurrent.CountDownLatch(1);
+                final String[] errorHolder = new String[1];
+                service.enroll(alias, config.getEstServerUrl(), null, "CN=" + alias,
+                        Collections.<String>emptyList(), "EC", "SHA384withECDSA", caPem, new Bundle(),
+                        new IEnrollmentCallback.Stub() {
+                            @Override
+                            public void onSuccess(byte[] certificateData) {
+                                enrollLatch.countDown();
+                            }
+                            @Override
+                            public void onError(String errorMessage) {
+                                errorHolder[0] = errorMessage;
+                                enrollLatch.countDown();
+                            }
+                        });
+                enrollLatch.await();
+                if (errorHolder[0] != null) {
+                    Log.e(TAG, "EST enrollment failed: " + errorHolder[0]);
+                    return null;
+                }
+                Log.i(TAG, "EST enrollment succeeded for alias: " + alias);
+            }
+            return alias;
+        } catch (Exception e) {
+            Log.e(TAG, "Exception during client identity selection", e);
+        }
+        return null;
+    }
+
+    @Override
+    public String chooseClientAlias(String[] keyType, Principal[] issuers, Socket socket) {
+        String hostname = getHostname(socket);
+        String alias = chooseAlias(keyType, issuers, hostname);
+        if (alias != null) {
+            return alias;
+        }
+        if (mDelegate != null) {
+            return mDelegate.chooseClientAlias(keyType, issuers, socket);
+        }
+        return null;
+    }
+
+    @Override
+    public String chooseEngineClientAlias(String[] keyType, Principal[] issuers, SSLEngine engine) {
+        String hostname = getHostname(engine);
+        String alias = chooseAlias(keyType, issuers, hostname);
+        if (alias != null) {
+            return alias;
+        }
+        if (mDelegate instanceof X509ExtendedKeyManager) {
+            return ((X509ExtendedKeyManager) mDelegate).chooseEngineClientAlias(keyType, issuers, engine);
+        } else if (mDelegate != null) {
+            return mDelegate.chooseClientAlias(keyType, issuers, null);
+        }
+        return null;
+    }
+
+    @Override
+    public String chooseServerAlias(String keyType, Principal[] issuers, Socket socket) {
+        if (mDelegate != null) {
+            return mDelegate.chooseServerAlias(keyType, issuers, socket);
+        }
+        return null;
+    }
+
+    @Override
+    public String chooseEngineServerAlias(String keyType, Principal[] issuers, SSLEngine engine) {
+        if (mDelegate instanceof X509ExtendedKeyManager) {
+            return ((X509ExtendedKeyManager) mDelegate).chooseEngineServerAlias(keyType, issuers, engine);
+        }
+        return null;
+    }
+
+    @Override
+    public X509Certificate[] getCertificateChain(String alias) {
+        Context context = getCurrentApplicationContext();
+        if (context == null) {
+            return mDelegate != null ? mDelegate.getCertificateChain(alias) : null;
+        }
+        INiapCertManager service = getService(context);
+        if (service != null) {
+            try {
+                if (service.hasEnrollment(alias)) {
+                    byte[] certBytes = service.getCertificateData(alias);
+                    if (certBytes != null && certBytes.length > 0) {
+                        CertificateFactory factory = CertificateFactory.getInstance("X.509");
+                        X509Certificate cert = (X509Certificate) factory.generateCertificate(
+                                new java.io.ByteArrayInputStream(certBytes));
+                        return new X509Certificate[] { cert };
+                    }
+                }
+            } catch (Exception e) {
+                Log.e(TAG, "Error fetching certificate chain from service", e);
+            }
+        }
+        if (mDelegate != null) {
+            return mDelegate.getCertificateChain(alias);
+        }
+        return null;
+    }
+
+    @Override
+    public PrivateKey getPrivateKey(final String alias) {
+        Context context = getCurrentApplicationContext();
+        if (context == null) {
+            return mDelegate != null ? mDelegate.getPrivateKey(alias) : null;
+        }
+        final INiapCertManager service = getService(context);
+        if (service != null) {
+            try {
+                if (service.hasEnrollment(alias)) {
+                    X509Certificate[] chain = getCertificateChain(alias);
+                    if (chain != null && chain.length > 0) {
+                        java.security.interfaces.ECPublicKey pubKey =
+                                (java.security.interfaces.ECPublicKey) chain[0].getPublicKey();
+                        RemotePrivateKey.Signer signer = new RemotePrivateKey.Signer() {
+                            @Override
+                            public byte[] sign(byte[] digest) {
+                                try {
+                                    return service.sign(alias, digest);
+                                } catch (Exception e) {
+                                    Log.e(TAG, "Error invoking signing oracle for alias: " + alias, e);
+                                    return null;
+                                }
+                            }
+                        };
+                        return new RemotePrivateKey(alias, pubKey.getParams(), signer);
+                    }
+                }
+            } catch (Exception e) {
+                Log.e(TAG, "Error recreating RemotePrivateKey", e);
+            }
+        }
+        if (mDelegate != null) {
+            return mDelegate.getPrivateKey(alias);
+        }
+        return null;
+    }
+
+    @Override
+    public String[] getClientAliases(String keyType, Principal[] issuers) {
+        if (mDelegate != null) {
+            return mDelegate.getClientAliases(keyType, issuers);
+        }
+        return null;
+    }
+
+    @Override
+    public String[] getServerAliases(String keyType, Principal[] issuers) {
+        if (mDelegate != null) {
+            return mDelegate.getServerAliases(keyType, issuers);
+        }
+        return null;
+    }
+
+    private static Context getCurrentApplicationContext() {
+        try {
+            Class<?> activityThreadClass = Class.forName("android.app.ActivityThread");
+            Method currentApplicationMethod = activityThreadClass.getMethod("currentApplication");
+            return (Context) currentApplicationMethod.invoke(null);
+        } catch (Exception e) {
+            Log.e(TAG, "Failed to retrieve application context via reflection", e);
+            return null;
+        }
+    }
+}
