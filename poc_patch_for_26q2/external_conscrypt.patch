+    private void checkNiapStrictProfile(List<X509Certificate> chain, Object connectionContext, String host) throws CertificateException {
+        String profile = mNetworkSecurityConfig.getSecurityProfile();
+        if (!"niap-strict".equals(profile) && !"custom".equals(profile)) {
+            return;
+        }
+
+        String peerHost = host;
+        if (peerHost == null || peerHost.isEmpty()) {
+            if (connectionContext instanceof javax.net.ssl.SSLSocket) {
+                javax.net.ssl.SSLSession session = ((javax.net.ssl.SSLSocket) connectionContext).getHandshakeSession();
+                if (session == null) {
+                    session = ((javax.net.ssl.SSLSocket) connectionContext).getSession();
+                }
+                if (session != null) {
+                    peerHost = session.getPeerHost();
+                }
+            } else if (connectionContext instanceof javax.net.ssl.SSLEngine) {
+                javax.net.ssl.SSLSession session = ((javax.net.ssl.SSLEngine) connectionContext).getHandshakeSession();
+                if (session == null) {
+                    session = ((javax.net.ssl.SSLEngine) connectionContext).getSession();
+                }
+                if (session != null) {
+                    peerHost = session.getPeerHost();
+                }
+            }
+        }
+        if (peerHost == null || peerHost.isEmpty()) {
+            peerHost = "UNKNOWN_HOST";
+        }
+
+        boolean strictSigAlg = mNetworkSecurityConfig.getNiapStrictSigAlg();
+        Set<String> prohibitedWildcards = mNetworkSecurityConfig.getProhibitedTldWildcards();
+        List<String> allowedCiphers = mNetworkSecurityConfig.getAllowedCipherSuites();
+        String limitTls = mNetworkSecurityConfig.getLimitTlsVersion();
+        boolean enforceExtensions = mNetworkSecurityConfig.getEnforceMandatoryExtensions();
+        boolean enforceEku = mNetworkSecurityConfig.getEnforceEku();
+        String requiredEku = mNetworkSecurityConfig.getRequiredEku();
+        boolean enforceCa = mNetworkSecurityConfig.getEnforceCaConstraints();
+
+        android.util.Log.i("NetworkSecurityTrustManager", "Enforcing NIAP validation for host: " + peerHost + " | Profile: " + profile);
+        if (chain == null || chain.isEmpty()) {
+            throw new CertificateException("NIAP profile for " + peerHost + ": Certificate chain is empty");
+        }
+        X509Certificate leafCert = chain.get(0);
+
+        // 1. Connection (Session) Context Constraints
+        if (connectionContext != null) {
+            try {
+                javax.net.ssl.SSLSession session = null;
+                if (connectionContext instanceof javax.net.ssl.SSLSocket) {
+                    session = ((javax.net.ssl.SSLSocket) connectionContext).getHandshakeSession();
+                    if (session == null) {
+                        session = ((javax.net.ssl.SSLSocket) connectionContext).getSession();
+                    }
+                } else if (connectionContext instanceof javax.net.ssl.SSLEngine) {
+                    session = ((javax.net.ssl.SSLEngine) connectionContext).getHandshakeSession();
+                    if (session == null) {
+                        session = ((javax.net.ssl.SSLEngine) connectionContext).getSession();
+                    }
+                }
+
+                if (session != null) {
+                    // 1.a Limit TLS Version
+                    String protocol = session.getProtocol(); // e.g. "TLSv1.3", "TLSv1.2"
+                    if ("1.2".equals(limitTls)) {
+                        if (protocol != null && !protocol.equals("TLSv1.2")) {
+                            String msg = "Host: " + peerHost + " | TLS protocol version " + protocol + " is not allowed. (Strictly limited to TLS 1.2)";
+                            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                            throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                        }
+                    } else {
+                        // Default NIAP restriction: Block weak versions (TLS 1.1, 1.0, SSL)
+                        if (protocol != null && (protocol.equals("TLSv1") || protocol.equals("TLSv1.1") || protocol.contains("SSL"))) {
+                            String msg = "Host: " + peerHost + " | TLS protocol version " + protocol + " is prohibited. (Must be TLSv1.2 or TLSv1.3)";
+                            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                            throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                        }
+                    }
+
+                    // 1.b Allowed Cipher Suites
+                    if (allowedCiphers != null && !allowedCiphers.isEmpty()) {
+                        String cipherSuite = session.getCipherSuite();
+                        if (cipherSuite != null && !allowedCiphers.contains(cipherSuite)) {
+                            String msg = "Host: " + peerHost + " | Cipher suite " + cipherSuite + " is not in the allowed list";
+                            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                            throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                        }
+                    }
+                }
+            } catch (Exception e) {
+                if (e instanceof CertificateException) {
+                    throw (CertificateException) e;
+                }
+                android.util.Log.w("NetworkSecurityTrustManager", "Host: " + peerHost + " | Could not extract SSLSession parameters for verification", e);
+            }
+        }
+
+        // 2. Algorithm Constraints (Keys & Signature Algorithm)
+        if (strictSigAlg) {
+            String sigAlgName = leafCert.getSigAlgName();
+            if (sigAlgName != null && !sigAlgName.toUpperCase(java.util.Locale.US).contains("SHA384") && 
+                !sigAlgName.toUpperCase(java.util.Locale.US).contains("SHA512")) {
+                String msg = "Host: " + peerHost + " | Signature algorithm must use SHA-384 or SHA-512: " + sigAlgName;
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        }
+
+        java.security.PublicKey pubKey = leafCert.getPublicKey();
+        if (pubKey instanceof java.security.interfaces.RSAPublicKey) {
+            int keySize = ((java.security.interfaces.RSAPublicKey) pubKey).getModulus().bitLength();
+            int minRsa = mNetworkSecurityConfig.getNiapMinRsaKeySize();
+            if (keySize < minRsa) {
+                String msg = "Host: " + peerHost + " | RSA key size " + keySize + " is less than required " + minRsa;
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        } else if (pubKey instanceof java.security.interfaces.ECPublicKey) {
+            int fieldSize = ((java.security.interfaces.ECPublicKey) pubKey).getParams().getCurve().getField().getFieldSize();
+            int minEc = mNetworkSecurityConfig.getNiapMinEcKeySize();
+            if (fieldSize < minEc) {
+                String msg = "Host: " + peerHost + " | EC key size " + fieldSize + " is less than required " + minEc;
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        } else {
+            String msg = "Host: " + peerHost + " | Unsupported public key type: " + pubKey.getAlgorithm();
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+            throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+        }
+
+        // 3. Mandatory Extensions
+        if (enforceExtensions) {
+            Set<String> nonCriticalOids = leafCert.getNonCriticalExtensionOIDs();
+            Set<String> criticalOids = leafCert.getCriticalExtensionOIDs();
+            Set<String> allOids = new android.util.ArraySet<>();
+            if (nonCriticalOids != null) allOids.addAll(nonCriticalOids);
+            if (criticalOids != null) allOids.addAll(criticalOids);
+
+            String[] mandatoryOids = { "2.5.29.35", "2.5.29.14", "2.5.29.15" };
+            for (String oid : mandatoryOids) {
+                if (!allOids.contains(oid)) {
+                    String msg = "Host: " + peerHost + " | Mandatory extension missing: " + oid;
+                    android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                    throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                }
+            }
+        }
+
+        // 4. Extended Key Usage (EKU)
+        if (enforceEku) {
+            try {
+                List<String> eku = leafCert.getExtendedKeyUsage();
+                String targetOid = "1.3.6.1.5.5.7.3.1"; // serverAuth OID
+                if ("clientAuth".equalsIgnoreCase(requiredEku)) {
+                    targetOid = "1.3.6.1.5.5.7.3.2";
+                } else if (requiredEku != null && requiredEku.contains(".")) {
+                    targetOid = requiredEku;
+                }
+                if (eku != null) {
+                    if (!eku.contains(targetOid)) {
+                        String msg = "Host: " + peerHost + " | Leaf certificate missing required EKU: " + requiredEku + " (" + targetOid + ")";
+                        android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                        throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                    }
+                } else {
+                    String msg = "Host: " + peerHost + " | Leaf certificate missing Extended Key Usage extension";
+                    android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                    throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                }
+            } catch (java.security.cert.CertificateParsingException e) {
+                String msg = "Host: " + peerHost + " | Failed to parse EKU";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg, e));
+            }
+        }
+
+        // 5. CA Constraints Check
+        if (enforceCa) {
+            int basicConstraints = leafCert.getBasicConstraints();
+            if (basicConstraints >= 0) {
+                String msg = "Host: " + peerHost + " | Leaf certificate must not be a CA";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        }
+
+        // 6. Prohibited TLD Wildcard Check
+        if (prohibitedWildcards != null && !prohibitedWildcards.isEmpty()) {
+            try {
+                Collection<List<?>> subAltNames = leafCert.getSubjectAlternativeNames();
+                if (subAltNames != null) {
+                    for (List<?> tldList : subAltNames) {
+                        if (tldList.size() >= 2) {
+                            String dnsName = tldList.get(1).toString().toUpperCase(java.util.Locale.US);
+                            if (prohibitedWildcards.contains(dnsName)) {
+                                String msg = "Host: " + peerHost + " | Failed wildcard TLD check: " + dnsName;
+                                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                            }
+                        }
+                    }
+                }
+            } catch (java.security.cert.CertificateParsingException e) {
+                String msg = "Host: " + peerHost + " | Failed to parse SANs";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+                throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg, e));
+            }
+        }
+
+        // 7. Revocation Checks (OCSP / CRL)
+        checkRevocation(chain, peerHost);
+
+        android.util.Log.i("NetworkSecurityTrustManager", "Host: " + peerHost + " | NIAP validation passed");
+    }
+
+    private void checkRevocation(List<X509Certificate> chain, String peerHost) throws CertificateException {
+        try {
+            java.security.cert.CertificateFactory certFactory = java.security.cert.CertificateFactory.getInstance("X.509");
+            List<X509Certificate> leafCerts = new java.util.ArrayList<>();
+            for (X509Certificate cert : chain) {
+                if (cert.getSubjectDN() == null || cert.getIssuerDN() == null) {
+                    leafCerts.add(cert);
+                    continue;
+                }
+                if (!cert.getSubjectDN().getName().equals(cert.getIssuerDN().getName())) {
+                    leafCerts.add(cert);
+                }
+            }
+            if (leafCerts.isEmpty()) {
+                String msg = "No non-root certificates found in chain";
+                android.util.Log.e("NetworkSecurityTrustManager", "Host: " + peerHost + " | NIAP Violation: " + msg);
+                throw new java.security.cert.CertPathValidatorException("NIAP profile: " + msg);
+            }
+            java.security.cert.CertPath path = certFactory.generateCertPath(leafCerts);
+            java.security.KeyStore ks = java.security.KeyStore.getInstance("AndroidCAStore");
+            ks.load(null, null);
+            java.security.cert.CertPathValidator cpv = java.security.cert.CertPathValidator.getInstance("PKIX");
+            java.security.cert.PKIXParameters params = new java.security.cert.PKIXParameters(ks);
+            String mode = mNetworkSecurityConfig.getNiapPkixRevocationMode();
+            if ("none".equals(mode)) {
+                android.util.Log.i("NetworkSecurityTrustManager", "Host: " + peerHost + " | Skipping revocation check (mode: none)");
+                return;
+            }
+            params.setRevocationEnabled(true);
+            java.security.cert.PKIXRevocationChecker checker = (java.security.cert.PKIXRevocationChecker) cpv.getRevocationChecker();
+            if ("lax".equals(mode)) {
+                checker.setOptions(java.util.EnumSet.of(
+                        java.security.cert.PKIXRevocationChecker.Option.NO_FALLBACK,
+                        java.security.cert.PKIXRevocationChecker.Option.ONLY_END_ENTITY,
+                        java.security.cert.PKIXRevocationChecker.Option.SOFT_FAIL
+                ));
+            } else {
+                checker.setOptions(java.util.EnumSet.of(java.security.cert.PKIXRevocationChecker.Option.NO_FALLBACK));
+            }
+            params.addCertPathChecker(checker);
+            cpv.validate(path, params);
+        } catch (Exception e) {
+            String msg = "Host: " + peerHost + " | Revocation check failed: " + e.getMessage();
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+            throw new CertificateException("NIAP profile: " + msg, new java.security.cert.CertPathValidatorException(msg, e));
+        }
+    }
 }
