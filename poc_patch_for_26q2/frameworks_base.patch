+
+    private void checkNiapStrictProfile(List<X509Certificate> chain) throws CertificateException {
+        if (!"niap-strict".equals(mNetworkSecurityConfig.getSecurityProfile())) {
+            return;
+        }
+        android.util.Log.i("NetworkSecurityTrustManager", "Enforcing NIAP strict validation for connection");
+        if (chain == null || chain.isEmpty()) {
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: Certificate chain is empty");
+            throw new CertificateException("NIAP strict profile: Certificate chain is empty");
+        }
+        X509Certificate leafCert = chain.get(0);
+        
+        // 1. Algorithm Constraints
+        String sigAlgName = leafCert.getSigAlgName();
+        if (sigAlgName != null && !sigAlgName.toUpperCase(java.util.Locale.US).contains("SHA384") && 
+            !sigAlgName.toUpperCase(java.util.Locale.US).contains("SHA512")) {
+            String msg = "Signature algorithm must use SHA-384 or SHA-512: " + sigAlgName;
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+            throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+        }
+        
+        java.security.PublicKey pubKey = leafCert.getPublicKey();
+        if (pubKey instanceof java.security.interfaces.RSAPublicKey) {
+            int keySize = ((java.security.interfaces.RSAPublicKey) pubKey).getModulus().bitLength();
+            if (keySize < 3072) {
+                String msg = "RSA key size " + keySize + " is less than required 3072";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        } else if (pubKey instanceof java.security.interfaces.ECPublicKey) {
+            int fieldSize = ((java.security.interfaces.ECPublicKey) pubKey).getParams().getCurve().getField().getFieldSize();
+            if (fieldSize < 384) {
+                String msg = "EC key size " + fieldSize + " is less than required 384";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        } else {
+            String msg = "Unsupported public key type: " + pubKey.getAlgorithm();
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+            throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+        }
+
+        // 2. Mandatory Extensions
+        Set<String> nonCriticalOids = leafCert.getNonCriticalExtensionOIDs();
+        Set<String> criticalOids = leafCert.getCriticalExtensionOIDs();
+        Set<String> allOids = new android.util.ArraySet<>();
+        if (nonCriticalOids != null) allOids.addAll(nonCriticalOids);
+        if (criticalOids != null) allOids.addAll(criticalOids);
+
+        String[] mandatoryOids = { "2.5.29.35", "2.5.29.14", "2.5.29.15" };
+        for (String oid : mandatoryOids) {
+            if (!allOids.contains(oid)) {
+                String msg = "Mandatory extension missing: " + oid;
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        }
+
+        // 3. Field Enforcement (EKU, Basic Constraints)
+        try {
+            List<String> eku = leafCert.getExtendedKeyUsage();
+            if (eku != null) {
+                if (!eku.contains("1.3.6.1.5.5.7.3.1")) {
+                    String msg = "Leaf certificate missing required EKU: serverAuth (1.3.6.1.5.5.7.3.1)";
+                    android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                    throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                }
+            } else {
+                String msg = "Leaf certificate missing Extended Key Usage extension";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+            }
+        } catch (java.security.cert.CertificateParsingException e) {
+            String msg = "Failed to parse EKU";
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+            throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg, e));
+        }
+
+        int basicConstraints = leafCert.getBasicConstraints();
+        if (basicConstraints >= 0) {
+            String msg = "Leaf certificate must not be a CA";
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+            throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+        }
+
+        // 4. TLD Wildcard Check
+        try {
+            Collection<List<?>> subAltNames = leafCert.getSubjectAlternativeNames();
+            if (subAltNames != null) {
+                Set<String> prohibitedTlds = new android.util.ArraySet<>(java.util.Arrays.asList("*.COM", "*.NET", "*.ORG"));
+                for (List<?> tldList : subAltNames) {
+                    if (tldList.size() >= 2) {
+                        String dnsName = tldList.get(1).toString().toUpperCase(java.util.Locale.US);
+                        if (prohibitedTlds.contains(dnsName)) {
+                            String msg = "Failed wildcard TLD check: " + dnsName;
+                            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                            throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg));
+                        }
+                    }
+                }
+            }
+        } catch (java.security.cert.CertificateParsingException e) {
+            String msg = "Failed to parse SANs";
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+            throw new CertificateException("NIAP strict profile: " + msg, new java.security.cert.CertPathValidatorException(msg, e));
+        }
+
+        // 5. Revocation Checks (OCSP / CRL)
+        checkRevocation(chain);
+        
+        android.util.Log.i("NetworkSecurityTrustManager", "NIAP strict validation passed");
+    }
+
+    private void checkRevocation(List<X509Certificate> chain) throws CertificateException {
+        try {
+            java.security.cert.CertificateFactory certFactory = java.security.cert.CertificateFactory.getInstance("X.509");
+            List<X509Certificate> leafCerts = new java.util.ArrayList<>();
+            for (X509Certificate cert : chain) {
+                if (cert.getSubjectDN() == null || cert.getIssuerDN() == null) {
+                    leafCerts.add(cert);
+                    continue;
+                }
+                if (!cert.getSubjectDN().getName().equals(cert.getIssuerDN().getName())) {
+                    leafCerts.add(cert);
+                }
+            }
+            if (leafCerts.isEmpty()) {
+                String msg = "No non-root certificates found in chain";
+                android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg);
+                throw new java.security.cert.CertPathValidatorException("NIAP strict profile: " + msg);
+            }
+            java.security.cert.CertPath path = certFactory.generateCertPath(leafCerts);
+            java.security.KeyStore ks = java.security.KeyStore.getInstance("AndroidCAStore");
+            ks.load(null, null);
+            java.security.cert.CertPathValidator cpv = java.security.cert.CertPathValidator.getInstance("PKIX");
+            java.security.cert.PKIXParameters params = new java.security.cert.PKIXParameters(ks);
+            params.setRevocationEnabled(true);
+            
+            java.security.cert.PKIXRevocationChecker checker = (java.security.cert.PKIXRevocationChecker) cpv.getRevocationChecker();
+            checker.setOptions(java.util.EnumSet.of(java.security.cert.PKIXRevocationChecker.Option.NO_FALLBACK));
+            params.addCertPathChecker(checker);
+            
+            cpv.validate(path, params);
+        } catch (java.security.cert.CertPathValidatorException e) {
+            String msg = "CertPath validation failed: " + e.getMessage();
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+            throw new CertificateException("NIAP strict profile: " + msg, e);
+        } catch (java.security.GeneralSecurityException | java.io.IOException e) {
+            String msg = "Security exception during CertPath validation";
+            android.util.Log.e("NetworkSecurityTrustManager", "NIAP Violation: " + msg, e);
+            throw new CertificateException("NIAP strict profile: " + msg, e);
+        }
+    }
 }
